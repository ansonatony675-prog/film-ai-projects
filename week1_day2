    "@dataclass\n",
    "class Scene:\n",
    "    title: str\n",
    "    duration: float\n",
    "    mood: str\n",
    "    characters: List[str]\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.characters)\n",
    "\n",
    "class FilmScript:\n",
    "    \n",
    "    total_scripts = 0  \n",
    "    \n",
    "    def __init__(self, title, director):\n",
    "        self.title = title\n",
    "        self.director = director\n",
    "        self.scenes: List[Scene] = []\n",
    "        FilmScript.total_scripts += 1\n",
    "    \n",
    "    \n",
    "    def add_scene(self, scene: Scene):\n",
    "        self.scenes.append(scene)\n",
    "        print(f\"✅ Scene '{scene.title}' added to '{self.title}'\")\n",
    "    \n",
    "    \n",
    "    @property\n",
    "    def total_duration(self):\n",
    "        total = sum(s.duration for s in self.scenes)\n",
    "        minutes = total / 60\n",
    "        return f\"{minutes:.1f} minutes\"\n",
    "    \n",
    "    \n",
    "    def scenes_by_mood(self, mood: str):\n",
    "        return [s for s in self.scenes if s.mood == mood]\n",
    "    \n",
    "\n",
    "    @classmethod\n",
    "    def get_total_scripts(cls):\n",
    "        return f\"Total scripts created: {cls.total_scripts}\"\n",
    "    \n",
    "    \n",
    "    @staticmethod\n",
    "    def format_duration(seconds: float):\n",
    "        mins = int(seconds // 60)\n",
    "        secs = int(seconds % 60)\n",
    "        return f\"{mins}m {secs}s\"\n",
    "\n",
