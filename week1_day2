    "from dataclasses import dataclass\n",
    "from typing import List\n",
    "\n",
    "@dataclass\n",
    "class Scene:\n",
    "    title: str\n",
    "    duration: float\n",
    "    mood: str\n",
    "    characters: List[str]\n",
    "\n",
    "    \n",
    "    def __len__(self):\n",
    "        return len(self.characters)\n",
    "    \n",
    "    \n",
    "    def __lt__(self, other):\n",
    "        return self.duration < other.duration\n",
    "    \n",
    "    def __eq__(self, other):\n",
    "        return self.title == other.title\n",
    "    \n",
    "    \n",
    "    def __add__(self, other):\n",
    "        return Scene(\n",
    "            title=f\"{self.title} + {other.title}\",\n",
    "            duration=self.duration + other.duration,\n",
    "            mood=self.mood,\n",
    "            characters=list(set(self.characters + other.characters))\n",
    "        )\n",
    "\n",
    "scene1 = Scene(\"Opening\", 120, \"calm\", [\"Anna\", \"Bob\"])\n",
    "scene2 = Scene(\"Climax\", 300, \"thrilling\", [\"Anna\", \"Villain\"])\n",
    "scene3 = Scene(\"Opening\", 90, \"calm\", [\"Chris\"])\n",
    "\n",
    "print(\"=== Dunder Methods ===\")\n",
    "print(f\"__len__  → Characters in scene1: {len(scene1)}\")\n",
    "print(f\"__lt__   → Is scene1 shorter than scene2? {scene1 < scene2}\")\n",
    "print(f\"__eq__   → Is scene1 == scene3 (same title)? {scene1 == scene3}\")\n",
    "\n",
    "merged = scene1 + scene2\n",
    "print(f\"\\n__add__  → Merged scene: {merged.title}\")\n",
    "print(f\"         → Duration: {merged.duration}s\")\n",
    "print(f\"         → Characters: {merged.characters}\")\n",
    "\n",
    "\n",
    "scenes = [scene2, scene1, scene3]\n",
    "sorted_scenes = sorted(scenes)\n",
    "print(f\"\\nSorted by duration:\")\n",
    "for s in sorted_scenes:\n",
    "    print(f\"  {s.title} → {s.duration}s\")"
